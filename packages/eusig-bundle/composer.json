{
    "name": "authentin/eusig-bundle",
    "description": "Symfony bundle for authentin/eusig — eIDAS signing with DI, config, and autowiring",
    "type": "symfony-bundle",
    "license": "MIT",
    "keywords": ["symfony", "pades", "xades", "cades", "electronic-signature", "pdf-signing", "bundle"],
    "require": {
        "php": ">=8.2",
        "authentin/eusig": "^0.1",
        "symfony/config": "^6.4 || ^7.0 || ^8.0",
        "symfony/dependency-injection": "^6.4 || ^7.0 || ^8.0",
        "symfony/http-kernel": "^6.4 || ^7.0 || ^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "symfony/http-client": "^6.4 || ^7.0 || ^8.0",
        "symfony/phpunit-bridge": "^6.4 || ^7.0 || ^8.0",
        "nyholm/psr7": "^1.8"
    },
    "autoload": {
        "psr-4": {
            "Authentin\\EusigBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Authentin\\EusigBundle\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    }
}
